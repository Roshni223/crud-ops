pipeline {
    agent any

    environment {
        JAR_NAME   = "sample-spring-boot-crud-example-with-h2-2.0.0-SNAPSHOT.jar"
        EC2_USER   = "ubuntu"
        EC2_HOST   = "13.48.31.123"
        DEPLOY_DIR = "/home/ubuntu/app"
        JAVA_OPTS  = "-Xms256m -Xmx512m"
    }

    tools {
        jdk 'JDK21'
        maven 'Maven3'
    }

    stages {

        stage('Build') {
            steps {
                sh '''
                    mvn clean package -DskipTests -Dmaven.test.skip=true
                    ls -l target/

                '''

            }
        }

        stage('Deploy') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    sh """
                        # 1. Ensure directory exists
                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} "mkdir -p ${DEPLOY_DIR}"

                        # 2. Copy the JAR
                        scp -o StrictHostKeyChecking=no target/${JAR_NAME} ${EC2_USER}@${EC2_HOST}:${DEPLOY_DIR}/${JAR_NAME}

                        # 3. Stop old process and start new one
                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} "
                            pkill -f '${JAR_NAME}' || true
                            sleep 2
                            nohup java ${JAVA_OPTS} -jar ${DEPLOY_DIR}/${JAR_NAME} > ${DEPLOY_DIR}/app.log 2>&1 &
                            sleep 5
                            disown
                        "
                    """
                }
            }
        }
    }
}