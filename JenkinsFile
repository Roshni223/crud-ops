pipeline {
    agent any

    environment {
        JAR_NAME   = "crud-ops-0.0.1-SNAPSHOT.jar"
        EC2_USER   = "ubuntu"
        EC2_HOST   = "13.48.31.123"
        DEPLOY_DIR = "/home/ubuntu/app"
        JAVA_OPTS  = "-Xms256m -Xmx512m"
        MAVEN_OPTS = "-Dmaven.repo.local=/var/lib/jenkins/.m2/repository"
    }

    tools {
        maven "Maven3"
    }

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests $MAVEN_OPTS'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test $MAVEN_OPTS'
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} \
                            'mkdir -p ${DEPLOY_DIR}'

                        scp -o StrictHostKeyChecking=no \
                            target/${JAR_NAME} \
                            ${EC2_USER}@${EC2_HOST}:${DEPLOY_DIR}/${JAR_NAME}

                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} '
                            pkill -f "${JAR_NAME}" || true
                            sleep 3
                            nohup java ${JAVA_OPTS} \
                                -jar ${DEPLOY_DIR}/${JAR_NAME} \
                                > ${DEPLOY_DIR}/app.log 2>&1 &
                            echo "App started with PID: \$!"
                        '
                    """
                }
            }
        }
    }

    post {
        success { echo '✅ Deployment successful!' }
        failure { echo '❌ Deployment failed. Check logs.' }
    }
}