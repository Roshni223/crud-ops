pipeline {
    agent any

    environment {
        APP_NAME       = "myapp"
        JAR_NAME       = "myapp-0.0.1-SNAPSHOT.jar"
        EC2_USER       = "ubuntu"
        EC2_HOST       = "13.51.206.53"
        DEPLOY_DIR     = "/home/ubuntu/app"
        JAVA_OPTS      = "-Xms256m -Xmx512m"
    }

    tools {
        maven "Maven3"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/your-username/your-repo.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(['ec2-ssh-key']) {

                    // Create app directory on EC2
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} \
                        'mkdir -p ${DEPLOY_DIR}'
                    """

                    // Copy JAR to EC2
                    sh """
                        scp -o StrictHostKeyChecking=no \
                        target/${JAR_NAME} \
                        ${EC2_USER}@${EC2_HOST}:${DEPLOY_DIR}/${JAR_NAME}
                    """

                    // Stop old instance and start new one
                    sh """
                        ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_HOST} '
                            # Kill existing app if running
                            PID=\$(pgrep -f "${JAR_NAME}") && kill \$PID || true
                            sleep 3

                            # Start new app in background
                            nohup java ${JAVA_OPTS} \
                              -jar ${DEPLOY_DIR}/${JAR_NAME} \
                              > ${DEPLOY_DIR}/app.log 2>&1 &

                            echo "App started with PID: \$!"
                        '
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ Deployment successful!"
        }
        failure {
            echo "❌ Deployment failed. Check logs."
        }
    }
}